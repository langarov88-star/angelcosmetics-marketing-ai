{
  "name": "angelcosmetics-marketing-ai",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev --config wrangler.jsonc",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply angelcosmetics-marketing-db --local",
    "db:migrate:staging": "wrangler d1 migrations apply angelcosmetics-marketing-db-staging --env staging",
    "db:migrate:prod": "wrangler d1 migrations apply angelcosmetics-marketing-db --env production"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250310.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1",
    "wrangler": "^4.0.0"
  }
}
