{
  "name": "angelcosmetics-agent-creative",
  "main": "src/workers/creative/index.ts",
  "compatibility_date": "2026-03-13",
  "compatibility_flags": ["nodejs_compat"],
  "queues": {
    "producers": [
      { "queue": "queue-results", "binding": "QUEUE_RESULTS" }
    ],
    "consumers": [
      { "queue": "queue-agent-creative", "max_batch_size": 3, "max_batch_timeout": 30 }
    ]
  },
  "d1_databases": [
    { "binding": "DB", "database_name": "angelcosmetics-marketing-db", "database_id": "REPLACE_WITH_D1_ID" }
  ],
  "kv_namespaces": [
    { "binding": "KV_CONFIG", "id": "REPLACE_WITH_KV_CONFIG_ID" },
    { "binding": "KV_CACHE",  "id": "REPLACE_WITH_KV_CACHE_ID" }
  ],
  "r2_buckets": [
    { "binding": "R2_ASSETS", "bucket_name": "angelcosmetics-assets" }
  ],
  "env": {
    "staging": { "name": "angelcosmetics-agent-creative-staging" },
    "production": { "name": "angelcosmetics-agent-creative" }
  }
}
